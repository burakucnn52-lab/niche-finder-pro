{
  "buildCommand": "",
  "outputDirectory": "public",
  "framework": null,
  "rewrites": [
    { "source": "/login", "destination": "/login.html" },
    { "source": "/register", "destination": "/register.html" },
    { "source": "/forgot-password", "destination": "/forgot-password.html" },
    { "source": "/reset-password", "destination": "/reset-password.html" },
    { "source": "/dashboard", "destination": "/dashboard.html" },
    { "source": "/nis-kesfi", "destination": "/nis-kesfi.html" },
    { "source": "/yukselen-kanallar", "destination": "/yukselen-kanallar.html" },
    { "source": "/kanal-analizi", "destination": "/kanal-analizi.html" },
    { "source": "/risk-detector", "destination": "/risk-detector.html" },
    { "source": "/ai-asistan", "destination": "/ai-asistan.html" },
    { "source": "/yol-haritasi", "destination": "/yol-haritasi.html" },
    { "source": "/admin", "destination": "/admin.html" },
    { "source": "/profil", "destination": "/profil.html" },
    { "source": "/fiyatlandirma", "destination": "/fiyatlandirma.html" },
    { "source": "/sss", "destination": "/sss.html" },
    { "source": "/gizlilik", "destination": "/gizlilik.html" },
    { "source": "/kvkk", "destination": "/kvkk.html" },
    { "source": "/sartlar", "destination": "/sartlar.html" }
  ],
  "headers": [
    {
      "source": "/(.*).html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/((?!api/).*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/css/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/js/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.(png|jpg|jpeg|gif|webp|svg|ico)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, must-revalidate"
        }
      ]
    }
  ]
}
